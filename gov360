     * INICIAR DIA
     * ================================================ */
    function renderCamareirasIniciarDia() {
      var container = document.getElementById('listaCamareirasDia');
      if (!container) return;

      if (!APP.camareiras.length) {
        container.innerHTML = '<div class="small">Nenhuma camareira cadastrada.</div>';
        return;
      }

      container.innerHTML = APP.camareiras.map(function(c) {
        return `
          <div class="checkbox-item">
            <input type="checkbox" value="${escapeHtml(c.nome)}" class="chk-camareira-dia">
            <div style="flex:1"><strong>${escapeHtml(c.nome)}</strong></div>
          </div>
        `;
      }).join('');
    }

    function atualizarBotaoIniciarDia() {
      var btn = document.getElementById('btnIniciarDia');
      if (!btn) return;
      if (APP.dashboard.statusDia === 'ABERTO') {
        btn.disabled    = true;
        btn.textContent = 'Dia já iniciado';
      } else {
        btn.disabled    = false;
        btn.textContent = 'Iniciar Dia';
      }
    }

    function handleIniciarDia() {
      var totalUH = Number(document.getElementById('inputTotalUH').value);

      if (!totalUH || totalUH <= 0) {
        alert('Informe a quantidade total de UH.');
        return;
      }

      var selecionadas = [];
      document.querySelectorAll('.chk-camareira-dia').forEach(function(chk) {
        if (chk.checked) selecionadas.push({ nome: chk.value });
      });

      if (!selecionadas.length) {
        alert('Selecione ao menos uma camareira.');
        return;
      }

      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) { alert(res.message); return; }
          APP.dashboard = res.data;
          APP.camareirasDoDia = selecionadas;
          updateDashboardUI();
          alert(res.message);
          showScreen('menu');
        })
        .withFailureHandler(function(e) { alert('Erro: ' + e.message); })
        .iniciarDia({ totalUH: totalUH, camareiras: selecionadas, usuario: APP.user.nome });
    }

