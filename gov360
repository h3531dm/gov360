    /* ================================================
     * DETECÇÃO DE ANDROID
     * Android Chrome/WebView tem suporte inconsistente ao <datalist>
     * Usa <select> nativo como fallback seguro
     * ================================================ */
    var IS_ANDROID = /android/i.test(navigator.userAgent);

    function renderRegistrarAuditoria() {
      var selectCam = document.getElementById('auditCamareira');
      var ncList    = document.getElementById('listaNaoConformidades');

      // --- CAMPO DE QUARTO: datalist (PC/iPhone) ou select (Android) ---
      var quartoWrap = document.getElementById('quartoFieldWrap');
      if (quartoWrap) {
        if (IS_ANDROID) {
          // Android: select nativo, sem datalist
          quartoWrap.innerHTML = `
            <label>Número do quarto</label>
            <select id="auditQuarto">
              <option value="">Selecione o quarto</option>
              ${APP.quartos.map(function(q) {
                return '<option value="' + escapeHtml(q.numero) + '">' +
                  escapeHtml(q.numero) + ' (' + escapeHtml(q.tipo) + ')</option>';
              }).join('')}
            </select>
          `;
        } else {
          // PC / iPhone: input com datalist
          quartoWrap.innerHTML = `
            <label>Número do quarto</label>
            <input list="quartosList" id="auditQuarto" placeholder="Digite ou selecione o quarto">
            <datalist id="quartosList">
              ${APP.quartos.map(function(q) {
                return '<option value="' + escapeHtml(q.numero) + '">' +
                  escapeHtml(q.numero) + ' (' + escapeHtml(q.tipo) + ')</option>';
              }).join('')}
            </datalist>
          `;
        }
      }

      if (ncList) {
        if (!APP.naoConformidades.length) {
          ncList.innerHTML = '<div class="small">Nenhuma não conformidade cadastrada.</div>';
        } else {
          ncList.innerHTML = APP.naoConformidades.map(function(nc) {
            return `
              <div class="checkbox-item">
                <input type="checkbox" class="chk-nc" value="${escapeHtml(nc.descricao)}">
                <div style="flex:1">${escapeHtml(nc.descricao)}</div>
              </div>
            `;
          }).join('');
        }
      }

      if (selectCam) {
        selectCam.innerHTML = '<option value="">Selecione</option>' +
          APP.camareirasDoDia.map(function(c) {
            return `<option value="${escapeHtml(c.nome)}">${escapeHtml(c.nome)}</option>`;
          }).join('');
      }

      limparFormularioAuditoria();
    }

    function onAreaTipoChange() {
      var areaTipo    = document.getElementById('auditAreaTipo').value;
      var quartoInput = document.getElementById('auditQuarto');
      if (areaTipo === 'AREA SOCIAL') {
        quartoInput.value    = '';
        quartoInput.disabled = true;
      } else {
        quartoInput.disabled = false;
      }
    }

    function onStatusChange() {
      var status = getSelectedStatusUh();
      var sec    = document.getElementById('naoConformeSection');
      if (!sec) return;
      if (status === 'NAO_CONFORME') {
        sec.classList.remove('hidden');
      } else {
        sec.classList.add('hidden');
      }
    }

    function getSelectedStatusUh() {
      var checked = document.querySelector('input[name="statusUh"]:checked');
      return checked ? checked.value : '';
    }

    function handleRegistrarAuditoria() {
      var areaTipo   = document.getElementById('auditAreaTipo').value;
      var camareira  = document.getElementById('auditCamareira').value;
      var quarto     = document.getElementById('auditQuarto').value.trim();
      var statusUh   = getSelectedStatusUh();
      var observacao = document.getElementById('auditObservacao').value.trim();

      var naoConformidades = [];
      document.querySelectorAll('.chk-nc').forEach(function(chk) {
        if (chk.checked) naoConformidades.push(chk.value);
      });

      if (!camareira)  { alert('Selecione a camareira.');          return; }
      if (!areaTipo)   { alert('Selecione o tipo de atuação.');    return; }
      if (areaTipo === 'QUARTOS' && !quarto) { alert('Informe o número do quarto.'); return; }
      if (!statusUh)   { alert('Selecione o status da UH.');       return; }
      if (statusUh === 'NAO_CONFORME' && !naoConformidades.length) {
        alert('Selecione ao menos uma não conformidade.');
        return;
      }

      // Verifica se ainda há fotos sendo enviadas
