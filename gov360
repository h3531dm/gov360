        html += '<table><thead><tr><th>Auditor</th><th>Total</th><th>Conformes</th><th>Não Conformes</th><th>Taxa de Conformidade</th></tr></thead><tbody>';
        data.forEach(function(r) {
          html += '<tr>' +
            '<td>' + escapeHtml(r.auditor) + '</td>' +
            '<td style="text-align:center">' + r.total + '</td>' +
