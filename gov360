    /* ================================================
     * FOTOS — Upload para Google Drive
     * ================================================ */

    // Array de objetos: { base64, mimeType, nome, linkUrl }
    // linkUrl é preenchido após upload bem-sucedido
    var FOTOS = [];
    var MAX_FOTOS = 3;

    function abrirSeletorFoto() {
      if (FOTOS.length >= MAX_FOTOS) {
        alert('Máximo de ' + MAX_FOTOS + ' fotos atingido.');
        return;
      }
      var input = document.getElementById('fotoInput');
      if (input) input.click();
    }

    function onFotoSelecionada(event) {
      var file = event.target.files && event.target.files[0];
      event.target.value = '';
      if (!file) return;

      if (FOTOS.length >= MAX_FOTOS) {
        alert('Máximo de ' + MAX_FOTOS + ' fotos atingido.');
        return;
      }

      var idx = FOTOS.length;
      FOTOS.push({ base64: null, mimeType: 'image/jpeg', nome: file.name, linkUrl: null, enviando: true });
      renderFotosPreviews();

      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          // Comprime via Canvas: máx 1200px, qualidade 75% JPEG
          var MAX_PX  = 1200;
          var w = img.width;
          var h = img.height;

          if (w > MAX_PX || h > MAX_PX) {
            if (w > h) { h = Math.round(h * MAX_PX / w); w = MAX_PX; }
            else       { w = Math.round(w * MAX_PX / h); h = MAX_PX; }
          }

          var canvas  = document.createElement('canvas');
          canvas.width  = w;
          canvas.height = h;
          canvas.getContext('2d').drawImage(img, 0, 0, w, h);

          var dataUrl  = canvas.toDataURL('image/jpeg', 0.75);
          var base64   = dataUrl.split(',')[1];
          var mimeType = 'image/jpeg';
          var nome     = 'foto_' + Date.now() + '_' + (idx + 1) + '.jpg';

          FOTOS[idx].base64   = base64;
          FOTOS[idx].dataUrl  = dataUrl;
          FOTOS[idx].mimeType = mimeType;
          FOTOS[idx].enviando = false;
          renderFotosPreviews();

          // Envia ao backend
          FOTOS[idx].enviando = true;
          renderFotosPreviews();

          google.script.run
            .withSuccessHandler(function(res) {
              if (res.success) {
                FOTOS[idx].linkUrl  = res.url;
                FOTOS[idx].enviando = false;
              } else {
                alert('Erro ao enviar foto: ' + res.message);
                FOTOS.splice(idx, 1);
              }
              renderFotosPreviews();
            })
            .withFailureHandler(function(e) {
              alert('Erro ao enviar foto: ' + e.message);
              FOTOS.splice(idx, 1);
              renderFotosPreviews();
            })
            .salvarFotoNoDrive({ base64: base64, mimeType: mimeType, nome: nome });
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    function removerFoto(idx) {
      FOTOS.splice(idx, 1);
      renderFotosPreviews();
    }

    function renderFotosPreviews() {
      var area = document.getElementById('fotoPreviewArea');
      var btn  = document.getElementById('btnAnexarFotoWrap');
      var msg  = document.getElementById('fotoStatusMsg');
      if (!area) return;

      area.innerHTML = FOTOS.map(function(f, i) {
        if (f.enviando) {
          return '<div class="foto-uploading">Enviando...</div>';
        }
        return '<div class="foto-thumb-wrap">' +
          '<img class="foto-thumb" src="' + (f.dataUrl || '') + '" alt="Foto ' + (i+1) + '">' +
          '<button class="foto-thumb-remove" onclick="removerFoto(' + i + ')" title="Remover foto">✕</button>' +
          '</div>';
      }).join('');

      // Esconde botão se atingiu o limite
      if (btn) btn.style.display = FOTOS.length >= MAX_FOTOS ? 'none' : '';

      // Mensagem de status
      if (msg) {
        var enviando = FOTOS.filter(function(f) { return f.enviando; }).length;
        if (enviando > 0) {
          msg.textContent = 'Enviando ' + enviando + ' foto(s)...';
        } else if (FOTOS.length > 0) {
          var ok = FOTOS.filter(function(f) { return f.linkUrl; }).length;
          msg.textContent = ok + ' de ' + FOTOS.length + ' foto(s) salvas no Drive.';
        } else {
          msg.textContent = '';
        }
      }
    }

    function limparFotos() {
      FOTOS = [];
      renderFotosPreviews();
      var btn = document.getElementById('btnAnexarFotoWrap');
      if (btn) btn.style.display = '';
    }

    function getFotosLinks() {
      // Retorna array de até 3 links (string vazia se não houver)
      var links = ['', '', ''];
      FOTOS.forEach(function(f, i) {
        if (i < 3 && f.linkUrl) links[i] = f.linkUrl;
      });
      return links;
    }

