    function showScreen(screenName) {
      APP.currentScreen = screenName;
      localStorage.setItem('gov360_screen', screenName);

      document.querySelectorAll('.screen').forEach(function(el) {
        el.classList.remove('active');
      });

      var target = document.getElementById('screen-' + screenName);
      if (target) target.classList.add('active');

      // Ações específicas por tela
      if (screenName === 'iniciarDia')         renderCamareirasIniciarDia();
      if (screenName === 'registrarAuditoria') renderRegistrarAuditoria();
      if (screenName === 'diario')             carregarDiario();       // sem redirecionamento
      if (screenName === 'dashboard')          updateDashboardUI();
      if (screenName === 'relatorios') { popularPessoasRelatorio(); setTimeout(inicializarCalendarios, 100); }
    }

    /* ================================================
     * LOGIN / LOGOUT
     * ================================================ */
    function handleLogin() {
      var usuario = document.getElementById('loginUsuario').value.trim();
      var senha   = document.getElementById('loginSenha').value.trim();

      if (!usuario || !senha) {
        alert('Informe usuário e senha.');
        return;
      }

      var btn = document.getElementById('btnEntrar');
      if (btn) { btn.disabled = true; btn.textContent = 'Aguarde...'; }

      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) {
            if (btn) { btn.disabled = false; btn.textContent = 'Entrar'; }
            alert(res.message);
            return;
          }

          APP.user = res.user;
          localStorage.setItem('gov360_user', JSON.stringify(APP.user));

          renderApp();
          preloadData(function() {
            refreshDashboard();
            startPolling();
            showScreen('menu');
          });
        })
        .withFailureHandler(function(err) {
          if (btn) { btn.disabled = false; btn.textContent = 'Entrar'; }
          alert('Erro no login: ' + err.message);
        })
        .login(usuario, senha);
    }

    function logout() {
      stopPolling();
      APP.user = null;
      APP.currentScreen = 'login';
      localStorage.removeItem('gov360_user');
      localStorage.removeItem('gov360_screen');
      renderApp();
      showScreen('login');
    }

    /* ================================================
     * PRELOAD DE DADOS BASE
     * Carrega em paralelo em vez de callback hell
     * ================================================ */
    function preloadData(callback) {
      var pendente = 4;
      var erros = [];

      function check() {
        pendente--;
        if (pendente === 0) {
          if (erros.length) console.warn('Preload com erros:', erros);
          if (callback) callback();
        }
      }

      google.script.run
        .withSuccessHandler(function(res) { APP.quartos = res.success ? res.data : []; check(); })
        .withFailureHandler(function(e)   { erros.push('quartos: ' + e.message); check(); })
        .getQuartos();

      google.script.run
        .withSuccessHandler(function(res) { APP.camareiras = res.success ? res.data : []; check(); })
        .withFailureHandler(function(e)   { erros.push('camareiras: ' + e.message); check(); })
        .getCamareiras();

      google.script.run
        .withSuccessHandler(function(res) { APP.naoConformidades = res.success ? res.data : []; check(); })
        .withFailureHandler(function(e)   { erros.push('naoConformidades: ' + e.message); check(); })
        .getNaoConformidades();

      google.script.run
        .withSuccessHandler(function(res) { APP.camareirasDoDia = res.success ? res.data : []; check(); })
        .withFailureHandler(function(e)   { erros.push('camareirasDoDia: ' + e.message); check(); })
        .getCamareirasDoDia();
    }

    /* ================================================
     * POLLING
     * ================================================ */
    function startPolling() {
      stopPolling();
      APP.pollingInterval = setInterval(refreshDashboard, 5000);
    }

    function stopPolling() {
      if (APP.pollingInterval) {
        clearInterval(APP.pollingInterval);
        APP.pollingInterval = null;
      }
    }

    function refreshDashboard() {
      // Apenas getDashboardData no polling — reduz chamadas ao backend pela metade
      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) return;
          APP.dashboard = res.data;
          updateDashboardUI();
        })
        .getDashboardData();
    }

    function updateDashboardUI() {
      setText('statStatus',    APP.dashboard.statusDia);
      setText('statMeta',      APP.dashboard.metaDia);
      setText('statRealizada', APP.dashboard.realizada);
      setText('statFaltam',    APP.dashboard.faltam);

      setText('dashStatus',    APP.dashboard.statusDia);
      setText('dashMeta',      APP.dashboard.metaDia);
      setText('dashRealizada', APP.dashboard.realizada);
      setText('dashFaltam',    APP.dashboard.faltam);

      updateStatusClass('statStatus');
      updateStatusClass('dashStatus');
      atualizarBotaoIniciarDia();
      atualizarProgresso();
      atualizarDataDoDia();
    }

    function atualizarDataDoDia() {
      var el = document.getElementById('dataDoDia');
      if (!el) return;
      var agora = new Date();
      var diasSemana = ['Domingo','Segunda-feira','Terça-feira','Quarta-feira','Quinta-feira','Sexta-feira','Sábado'];
      var meses = ['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
      var diaSemana = diasSemana[agora.getDay()];
      var dia  = agora.getDate();
      var mes  = meses[agora.getMonth()];
      var ano  = agora.getFullYear();
      el.textContent = diaSemana + ', ' + dia + ' de ' + mes + ' de ' + ano;
    }

    function atualizarProgresso() {
      var wrap   = document.getElementById('progressoWrap');
      var bar    = document.getElementById('progressoBar');
      var label  = document.getElementById('progressoLabel');
      if (!wrap || !bar || !label) return;

      var meta      = Number(APP.dashboard.metaDia)   || 0;
      var realizada = Number(APP.dashboard.realizada)  || 0;

      if (meta > 0 && APP.dashboard.statusDia === 'ABERTO') {
        var pct = Math.min(Math.round((realizada / meta) * 100), 100);
        wrap.style.display  = 'block';
        bar.style.width     = pct + '%';
        bar.style.background = pct >= 100 ? 'var(--green)' : 'var(--blue-mid)';
        label.textContent   = realizada + ' de ' + meta + ' auditorias realizadas (' + pct + '%)';
      } else {
        wrap.style.display = 'none';
      }
    }

    function updateStatusClass(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.remove('status-open', 'status-closed');
      el.classList.add(APP.dashboard.statusDia === 'ABERTO' ? 'status-open' : 'status-closed');
    }

    function setText(id, value) {
      var el = document.getElementById(id);
      if (el) el.textContent = value;
    }

