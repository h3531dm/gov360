            '</tr>';
        });
        html += '</tbody></table></div>';
      }

      // ── 4. RANKING DE NÃO CONFORMIDADES ─────────────────────────────────
      else if (tipo === 'naoconformidades') {
        var totalOcorrencias = data.reduce(function(s, r) { return s + r.qtd; }, 0);
        html += '<div class="card" style="margin-top:16px;">';
        html += '<div class="rel-titulo">Ranking de Não Conformidades' + periodoTxt + '</div>';
        html += '<div class="rel-totais">';
        html += '<div class="rel-total-card"><div class="rel-total-label">Tipos Distintos</div><div class="rel-total-value">' + data.length + '</div></div>';
        html += '<div class="rel-total-card"><div class="rel-total-label">Total de Ocorrências</div><div class="rel-total-value vermelho">' + totalOcorrencias + '</div></div>';
        html += '</div>';
        html += '<table><thead><tr><th>#</th><th>Não Conformidade</th><th>Ocorrências</th><th>Frequência</th></tr></thead><tbody>';
        data.forEach(function(r, i) {
          var freq = totalOcorrencias > 0 ? Math.round((r.qtd / totalOcorrencias) * 100) : 0;
          html += '<tr>' +
            '<td><span class="ranking-num">' + (i + 1) + '</span></td>' +
            '<td>' + escapeHtml(r.descricao) + '</td>' +
            '<td style="text-align:center"><span class="badge-naoconforme">' + r.qtd + '</span></td>' +
            '<td><div class="taxa-bar-wrap"><div class="taxa-bar"><div class="taxa-bar-fill" style="width:' + freq + '%; background:var(--red)"></div></div><span class="taxa-txt">' + freq + '%</span></div></td>' +
            '</tr>';
        });
        html += '</tbody></table></div>';
      }

      box.innerHTML   = html;
      if (print) print.innerHTML = html;
    }

    /* ================================================
     * CONFIGURAÇÕES
     * ================================================ */
    function openConfiguracoes() {
      if (APP.user.nivel !== 0) { alert('Acesso negado.'); return; }

      // Carrega configurações atuais antes de exibir a tela
      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) { alert(res.message); return; }
          // Popula percentual atual
          var el = document.getElementById('cfgPercentual');
          if (el) el.value = res.data.percentualAuditoria || 50;
        })
        .getConfiguracoes(APP.user.nivel);

      showScreen('configuracoes');
    }

    function handleSalvarPercentual() {
      var el = document.getElementById('cfgPercentual');
      var percentual = Number(el ? el.value : 0);

      if (!percentual || percentual < 1 || percentual > 100) {
        alert('Informe um percentual válido entre 1 e 100.');
        return;
      }

      google.script.run
        .withSuccessHandler(function(res) { alert(res.message); })
        .withFailureHandler(function(e)   { alert('Erro: ' + e.message); })
        .salvarPercentualAuditoria(APP.user.nivel, percentual);
    }

    function handleCriarUsuario() {
      var usuario = document.getElementById('novoUsuario').value.trim();
      var senha   = document.getElementById('novaSenha').value.trim();
      var nome    = document.getElementById('novoNome').value.trim();
      var nivel   = Number(document.getElementById('novoNivel').value);
      var cargo   = document.getElementById('novoCargo').value.trim();

      if (!usuario || !senha || !nome) {
        alert('Preencha todos os campos.');
        return;
      }

      google.script.run
        .withSuccessHandler(function(res) {
          alert(res.message);
          if (res.success) {
            document.getElementById('novoUsuario').value = '';
            document.getElementById('novaSenha').value   = '';
            document.getElementById('novoNome').value    = '';
            document.getElementById('novoCargo').value   = '';
          }
        })
        .withFailureHandler(function(e) { alert('Erro: ' + e.message); })
        .criarUsuario(APP.user.nivel, { usuario: usuario, senha: senha, nome: nome, nivel: nivel, cargo: cargo });
    }

    function handleResetarSenha() {
      var usuario   = document.getElementById('resetUsuario').value.trim();
      var novaSenha = document.getElementById('resetNovaSenha').value.trim();

      if (!usuario || !novaSenha) {
        alert('Informe o usuário e a nova senha.');
        return;
      }

      google.script.run
        .withSuccessHandler(function(res) {
          alert(res.message);
          if (res.success) {
            document.getElementById('resetUsuario').value   = '';
            document.getElementById('resetNovaSenha').value = '';
          }
        })
        .withFailureHandler(function(e) { alert('Erro: ' + e.message); })
        .resetarSenha(APP.user.nivel, usuario, novaSenha);
    }

    function handleForcarReaberturaDia() {
      if (!confirm('Deseja realmente forçar a reabertura do dia?')) return;

      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) { alert(res.message); return; }
          // Atualiza dashboard com os valores preservados do encerramento
          if (res.data) APP.dashboard = res.data;
          updateDashboardUI();
          alert(res.message);
          showScreen('menu');
        })
        .withFailureHandler(function(e) { alert('Erro: ' + e.message); })
        .forcarReaberturaDia({ userNivel: APP.user.nivel });
    }

    /* ================================================
     * UTILITÁRIOS
     * ================================================ */
    function escapeHtml(str) {
      if (str === null || str === undefined) return '';
      return String(str)
        .replace(/&/g,  '&amp;')
        .replace(/</g,  '&lt;')
        .replace(/>/g,  '&gt;')
        .replace(/"/g,  '&quot;')
        .replace(/'/g,  '&#039;');
    }

    function getCargoNome(nivel) {
      if (nivel === 0) return 'Administrador';
      if (nivel === 1) return 'Operacional';
      if (nivel === 2) return 'Gerencial';
      return 'Usuário';
    }

    /* ================================================
     * MODAL DETALHE DE AUDITORIA
     * ================================================ */
    function abrirDetalheAuditoria(id) {
      var overlay = document.getElementById('modalDetalheOverlay');
      var corpo   = document.getElementById('modalDetalheCorpo');
      if (!overlay || !corpo) return;

      corpo.innerHTML = '<div class="notice notice-info">Carregando...</div>';
      overlay.classList.add('active');

      google.script.run
        .withSuccessHandler(function(res) {
          if (!res.success) {
            corpo.innerHTML = '<div class="notice notice-error">' + escapeHtml(res.message) + '</div>';
            return;
          }
          var r = res.data;
          var ncFormatado = r.naoConformidades
            ? r.naoConformidades.split('|').map(function(s) { return escapeHtml(s.trim()); }).join('<br>')
            : '—';
          var statusBadge = r.statusUh === 'CONFORME'
            ? '<span class="badge-conforme">Conforme</span>'
            : '<span class="badge-naoconforme">Não Conforme</span>';

          var conteudo =
            '<div class="modal-row"><span class="modal-label">Data</span><span class="modal-valor">' + escapeHtml(r.data) + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Hora</span><span class="modal-valor">' + escapeHtml(r.hora) + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Camareira</span><span class="modal-valor">' + escapeHtml(r.camareira) + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Quarto / Área</span><span class="modal-valor">' + escapeHtml(r.quarto || 'Área Social') + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Tipo</span><span class="modal-valor">' + escapeHtml(r.areaTipo) + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Status</span><span class="modal-valor">' + statusBadge + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Não Conformidades</span><span class="modal-valor">' + ncFormatado + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Observação</span><span class="modal-valor">' + escapeHtml(r.observacao || '—') + '</span></div>' +
            '<div class="modal-row"><span class="modal-label">Auditor</span><span class="modal-valor">' + escapeHtml(r.usuario) + '</span></div>' +
            renderFotosDetalhe([r.foto1, r.foto2, r.foto3]);

          // Preenche modal na tela
          corpo.innerHTML = conteudo;

          // Preenche bloco de impressão
          var agora = new Date();
          setText('detalhePrintUser', APP.user.nome);
          setText('detalhePrintDate', agora.toLocaleDateString('pt-BR') + ' ' + agora.toLocaleTimeString('pt-BR'));
          var printCorpo = document.getElementById('detalheAuditoriaPrintCorpo');
          if (printCorpo) {
            printCorpo.innerHTML =
              '<h2 style="color:#1F4E79;margin:0 0 16px 0;">Detalhe da Auditoria — Quarto ' + escapeHtml(r.quarto || 'Área Social') + '</h2>' +
              conteudo;
          }
        })
        .withFailureHandler(function(e) {
          corpo.innerHTML = '<div class="notice notice-error">Erro: ' + escapeHtml(e.message) + '</div>';
        })
        .getAuditoriaDetalhe(id);
    }

    /* ================================================
     * FOTOS NO DETALHE DA AUDITORIA
     * ================================================ */
    function renderFotosDetalhe(fotos) {
      var validas = fotos.filter(function(f) { return f && f.trim(); });
      if (!validas.length) return '';

      var imgs = validas.map(function(url) {
        var thumbUrl  = driveThumbUrl(url);
        var linkAbrir = driveLinkAbrir(url);
        return '<a href="' + escapeHtml(linkAbrir) + '" target="_blank" style="display:inline-block;">' +
          '<img src="' + escapeHtml(thumbUrl) + '" ' +
          'style="width:120px;height:90px;object-fit:cover;border-radius:6px;border:1px solid var(--border);" ' +
          'onerror="this.parentNode.innerHTML=\'<span style=&quot;font-size:11px;color:var(--muted)&quot;>Foto<br>salva</span>\'">' +
          '</a>';
      }).join('');

      return '<div class="modal-row" style="flex-direction:column;align-items:flex-start;">' +
        '<span class="modal-label" style="margin-bottom:8px;">Fotos</span>' +
        '<div class="foto-print-wrap" style="display:flex;gap:8px;flex-wrap:wrap;">' + imgs + '</div>' +
        '</div>';
    }

    // Extrai o fileId de qualquer formato de URL do Drive
    function driveFileId(url) {
      if (!url) return '';
      // formato: /uc?export=view&id=FILE_ID ou /thumbnail?id=FILE_ID ou /file/d/FILE_ID
      var m;
      m = url.match(/[?&]id=([^&]+)/);
      if (m) return m[1];
      m = url.match(/\/file\/d\/([^/]+)/);
      if (m) return m[1];
      return '';
    }

    // URL de thumbnail — carrega dentro do iframe do GAS sem bloqueio
    function driveThumbUrl(url) {
      var id = driveFileId(url);
      if (id) return 'https://drive.google.com/thumbnail?id=' + id + '&sz=w800';
      return url;
    }

    // URL para abrir a foto em tamanho original
    function driveLinkAbrir(url) {
      var id = driveFileId(url);
      if (id) return 'https://drive.google.com/file/d/' + id + '/view';
      return url;
    }

    function fecharDetalheAuditoria() {
      var overlay = document.getElementById('modalDetalheOverlay');
      if (overlay) overlay.classList.remove('active');
    }

    /* ================================================
     * IMPRESSÃO CENTRAL
     * Garante que só um bloco aparece por vez
     * ================================================ */
    function ativarPrint(idBloco) {
      // Remove classe de todos os blocos de print
      ['diarioPrint', 'relatorioPrint', 'detalheAuditoriaPrint'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.classList.remove('ativo-print');
      });
      // Ativa apenas o bloco solicitado
      var alvo = document.getElementById(idBloco);
      if (alvo) alvo.classList.add('ativo-print');
    }

    function imprimirDiario() {
      aplicarOrientacao('portrait');
      ativarPrint('diarioPrint');
      window.print();
    }

    function imprimirRelatorio() {
      var tipo = document.getElementById('relTipo') ? document.getElementById('relTipo').value : '';
      var orientacao = (tipo === 'analitico') ? 'landscape' : 'portrait';
      aplicarOrientacao(orientacao);
      ativarPrint('relatorioPrint');
      window.print();
    }

    function imprimirDetalheAuditoria() {
      fecharDetalheAuditoria();
      aplicarOrientacao('portrait');
      ativarPrint('detalheAuditoriaPrint');
      setTimeout(function() { window.print(); }, 200);
    }

    function aplicarOrientacao(orientacao) {
      var el = document.getElementById('printOrientacaoStyle');
      if (!el) {
        el = document.createElement('style');
        el.id = 'printOrientacaoStyle';
        document.head.appendChild(el);
      }
      el.textContent = '@page { size: ' + orientacao + '; margin: 1cm; }';
    }
  </script>
  <!-- MODAL: Detalhe da Auditoria -->
  <div id="modalDetalheOverlay" class="modal-overlay" onclick="fecharDetalheAuditoria()">
    <div class="modal-box" onclick="event.stopPropagation()">
      <button class="modal-fechar" onclick="fecharDetalheAuditoria()">✕ Fechar</button>
      <div class="modal-titulo">Detalhe da Auditoria</div>
      <div id="modalDetalheCorpo"></div>
      <div style="margin-top:20px; display:flex; gap:10px;">
        <button class="btn-light" onclick="imprimirDetalheAuditoria()">Imprimir</button>
      </div>
    </div>
  </div>

  <!-- IMPRESSÃO: Detalhe da Auditoria (oculto na tela) -->
  <div id="detalheAuditoriaPrint" style="display:none;">
    <div class="print-header">
      <div class="print-logo">Gov360 • Controle de Auditoria Operacional</div>
      <div class="print-info">
        <div>Usuário: <strong><span id="detalhePrintUser"></span></strong></div>
        <div>Gerado em: <span id="detalhePrintDate"></span></div>
      </div>
    </div>
    <div id="detalheAuditoriaPrintCorpo"></div>
  </div>

