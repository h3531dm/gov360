    function handleGerarRelatorio() {
      var tipo    = document.getElementById('relTipo').value;
      var pessoaEl = document.getElementById('relPessoa');
      // Para ranking de não conformidades, pessoa sempre vazia (visão geral)
      var pessoa  = (tipo === 'naoconformidades' || !pessoaEl) ? '' : pessoaEl.value;

      var dataIniBr = document.getElementById('relDataInicial').value.trim();
      var dataFimBr = document.getElementById('relDataFinal').value.trim();

      // Converte dd/mm/aaaa → yyyy-mm-dd para o backend
      function brParaIso(br) {
        if (!br || br.length < 10) return '';
        var p = br.split('/');
        if (p.length !== 3 || p[2].length !== 4) return '';
        return p[2] + '-' + p[1] + '-' + p[0];
      }

      var isoIni = brParaIso(dataIniBr);
      var isoFim = brParaIso(dataFimBr);

      if (dataIniBr && !isoIni) { alert('Data Inicial inválida. Use dd/mm/aaaa.'); return; }
      if (dataFimBr && !isoFim) { alert('Data Final inválida. Use dd/mm/aaaa.');   return; }

      var box = document.getElementById('relatoriosContent');
      box.innerHTML = '<div class="notice notice-info" style="margin-top:16px;">Gerando relatório...</div>';

      var btn = document.getElementById('btnGerarRelatorio');
      if (btn) { btn.disabled = true; btn.textContent = 'Aguarde...'; }

      google.script.run
        .withSuccessHandler(function(res) {
          if (btn) { btn.disabled = false; btn.textContent = 'Gerar Relatório'; }
          var box2 = document.getElementById('relatoriosContent');
          if (!res.success) {
            box2.innerHTML = '<div class="notice notice-error">' + escapeHtml(res.message) + '</div>';
            return;
          }
          renderRelatorio(res, tipo, dataIniBr, dataFimBr, pessoa);
        })
        .withFailureHandler(function(e) {
          if (btn) { btn.disabled = false; btn.textContent = 'Gerar Relatório'; }
          var box2 = document.getElementById('relatoriosContent');
          box2.innerHTML = '<div class="notice notice-error">Erro: ' + escapeHtml(e.message) + '</div>';
        })
        .getRelatoriosData({
          tipoRelatorio: tipo,
          pessoa:        pessoa,
          visaoGeral:    pessoa === '',
          dataInicial:   isoIni,
          dataFinal:     isoFim,
          userNivel:     APP.user.nivel
        });
    }

