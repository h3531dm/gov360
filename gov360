        html += '<div class="rel-total-card"><div class="rel-total-label">Conformes</div><div class="rel-total-value verde">' + confGeral + '</div></div>';
        html += '<div class="rel-total-card"><div class="rel-total-label">Não Conformes</div><div class="rel-total-value vermelho">' + ncGeral + '</div></div>';
        html += '<div class="rel-total-card"><div class="rel-total-label">Taxa Geral</div><div class="rel-total-value">' + (totalGeral > 0 ? Math.round((confGeral/totalGeral)*100) : 0) + '%</div></div>';
        html += '</div>';
        html += '<table><thead><tr><th>Camareira</th><th>Total</th><th>Conformes</th><th>Não Conformes</th><th>Taxa de Conformidade</th></tr></thead><tbody>';
        data.forEach(function(r) {
          html += '<tr>' +
            '<td>' + escapeHtml(r.camareira) + '</td>' +
            '<td style="text-align:center">' + r.total + '</td>' +
            '<td style="text-align:center"><span class="badge-conforme">' + r.conformes + '</span></td>' +
            '<td style="text-align:center"><span class="badge-naoconforme">' + r.naoConformes + '</span></td>' +
            '<td><div class="taxa-bar-wrap"><div class="taxa-bar"><div class="taxa-bar-fill" style="width:' + r.taxaConformidade + '%"></div></div><span class="taxa-txt">' + r.taxaConformidade + '%</span></div></td>' +
            '</tr>';
        });
        html += '</tbody></table></div>';
      }

      // ── 2. HISTÓRICO DE AUDITORIAS (analítico) ──────────────────────────
      else if (tipo === 'analitico') {
        html += '<div class="card" style="margin-top:16px;">';
        html += '<div class="rel-titulo">Histórico de Auditorias' + pessoaTxt + periodoTxt + '</div>';
        html += '<div class="rel-totais">';
        html += '<div class="rel-total-card"><div class="rel-total-label">Total de Registros</div><div class="rel-total-value">' + data.length + '</div></div>';
        html += '</div>';
        html += '<div style="overflow-x:auto"><table><thead><tr><th>Data</th><th>Hora</th><th>Camareira</th><th>Quarto / Área</th><th>Tipo</th><th>Status</th><th>Não Conformidades</th><th>Observação</th><th>Auditor</th><th>Fotos</th></tr></thead><tbody>';
