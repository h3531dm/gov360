<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gov360</title>
  <!-- Flatpickr: calendário leve com suporte PT-BR -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/l10n/pt.min.js"></script>
  <style>
    /* ========================
       PRINT
    ======================== */
    @media print {
      body * { visibility: hidden; }

      /* Só mostra o bloco marcado como ativo para impressão */
      .ativo-print, .ativo-print * { visibility: visible; }

      .ativo-print {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        display: block !important;
      }

      .print-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 2px solid #1F4E79;
        margin-bottom: 20px;
        padding-bottom: 12px;
      }

      .print-logo { font-size: 18px; font-weight: bold; color: #1F4E79; }
      .print-info { font-size: 12px; text-align: right; color: #444; line-height: 1.6; }

      table { width: 100%; border-collapse: collapse; }
      th { background: #1F4E79 !important; color: white !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      th, td { border: 1px solid #ccc; padding: 6px 8px; text-align: left; font-size: 11px; }
      tr:nth-child(even) td { background: #f5f5f5; }

      /* Fotos visíveis na impressão */
      .foto-print-wrap { display: flex; gap: 10px; flex-wrap: wrap; }
      .foto-print-wrap img {
        width: 280px !important;
        height: 210px !important;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ccc;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .modal-row { display: flex; gap: 8px; margin-bottom: 8px; font-size: 12px; }
      .modal-label { font-weight: bold; color: #444; min-width: 140px; }
      .badge-naoconforme { background: #fdeeee; color: #991B1B; padding: 2px 6px; border-radius: 4px; font-size: 11px; }
      .badge-conforme    { background: #edf7ee; color: #1E6B45; padding: 2px 6px; border-radius: 4px; font-size: 11px; }

      /* Paisagem para relatório analítico (muitas colunas) */
      .print-paisagem { }
      @page { margin: 1cm; }
      body.print-modo-paisagem { }
    }

    /* Forçar paisagem quando o bloco ativo for o analítico */
    @media print {
      .ativo-print.precisa-paisagem ~ * { display: none; }
    }

    /* Blocos de impressão invisíveis na tela */
    #diarioPrint           { display: none; }
    #relatorioPrint        { display: none; }
    #detalheAuditoriaPrint { display: none; }

    /* Card do diário visível apenas na tela */
    .diario-tela { display: block; }

    /* ========================
       RELATÓRIOS
    ======================== */
    .rel-totais {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin-bottom: 18px;
    }

    .rel-total-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .rel-total-label { font-size: 12px; color: var(--muted); margin-bottom: 6px; }
    .rel-total-value { font-size: 24px; font-weight: bold; color: var(--blue-dark); }
    .rel-total-value.verde  { color: var(--green); }
    .rel-total-value.vermelho { color: var(--red); }

    .rel-titulo {
      font-size: 16px;
      font-weight: bold;
      color: var(--blue-dark);
      margin: 0 0 14px 0;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--border);
    }

    .taxa-bar-wrap { display: flex; align-items: center; gap: 8px; }
    .taxa-bar { flex: 1; height: 8px; background: #e5e7eb; border-radius: 99px; overflow: hidden; }
    .taxa-bar-fill { height: 100%; border-radius: 99px; background: var(--green); }
    .taxa-txt { font-size: 12px; font-weight: bold; min-width: 36px; text-align: right; color: var(--muted); }

    .badge-conforme    { background: #edf7ee; color: var(--green); padding: 3px 8px; border-radius: 99px; font-size: 12px; font-weight: bold; }
    .badge-naoconforme { background: #fdeeee; color: var(--red);   padding: 3px 8px; border-radius: 99px; font-size: 12px; font-weight: bold; }

    .ranking-num { font-size: 18px; font-weight: bold; color: var(--blue-dark); width: 28px; text-align: center; }

    /* ========================
       FOTOS — MINIATURAS
    ======================== */
    .foto-thumb-wrap {
      position: relative;
      width: 80px;
      height: 80px;
      border-radius: 8px;
      overflow: visible;
      border: 1px solid var(--border);
    }

    .foto-thumb {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 8px;
      display: block;
    }

    .foto-thumb-remove {
      position: absolute;
      top: -8px;
      right: -8px;
      width: 22px;
      height: 22px;
      background: var(--red);
      color: #fff;
      border: none;
      border-radius: 50%;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      padding: 0;
    }

    .foto-uploading {
      width: 80px;
      height: 80px;
      border-radius: 8px;
      border: 1px dashed var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: var(--muted);
      text-align: center;
    }

    /* Link do quarto no relatório analítico */
    .link-quarto {
      color: var(--blue-dark);
      font-weight: bold;
      text-decoration: underline;
      cursor: pointer;
    }

    /* Modal de detalhe da auditoria */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.45);
      z-index: 2000;
      align-items: center;
      justify-content: center;
    }

    .modal-overlay.active { display: flex; }

    .modal-box {
      background: #fff;
      border-radius: var(--radius);
      box-shadow: 0 16px 48px rgba(0,0,0,0.18);
      padding: 28px;
      width: 100%;
      max-width: 560px;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }

    .modal-titulo {
      font-size: 18px;
      font-weight: bold;
      color: var(--blue-dark);
      margin: 0 0 18px 0;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--border);
    }

    .modal-fechar {
      position: absolute;
      top: 16px; right: 16px;
      background: #E8EEF4;
      border: none;
      border-radius: 8px;
      padding: 6px 12px;
      cursor: pointer;
      font-weight: bold;
      color: var(--blue-dark);
    }

    .modal-row { display: flex; gap: 8px; margin-bottom: 10px; font-size: 14px; }
    .modal-label { color: var(--muted); font-weight: bold; min-width: 140px; }
    .modal-valor { color: var(--text); flex: 1; }

    /* ========================
       DESIGN TOKENS — Paleta Corporativa
    ======================== */
    :root {
      --blue-dark:  #1A3F5C;   /* azul corporativo principal */
      --blue-mid:   #2563A8;   /* azul médio para destaques */
      --bg:         #F0F2F5;
      --white:      #FFFFFF;
      --text:       #1E2A38;
      --muted:      #64748B;
      --green:      #1E6B45;
      --slate:      #475569;   /* cinza azulado para ações secundárias */
      --red:        #991B1B;   /* vermelho sóbrio — só ações destrutivas */
      --border:     #D1DAE4;
      --shadow:     0 2px 12px rgba(0,0,0,0.07);
      --radius:     10px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    /* ========================
       TOPBAR
    ======================== */
    .topbar {
      background: var(--blue-dark);
      color: #fff;
      padding: 0 24px;
      height: 56px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    }

    .brand {
      font-size: 20px;
      font-weight: bold;
      letter-spacing: 1px;
      color: #fff;
    }

    /* Área do usuário melhorada */
    .userbox {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 8px;
      padding: 6px 14px;
      font-size: 13px;
    }

    .userbox-icon {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 13px;
      color: #fff;
      flex-shrink: 0;
    }

    .userbox-nome { font-weight: bold; color: #fff; }
    .userbox-cargo { font-size: 11px; color: rgba(255,255,255,0.65); }

    /* ========================
       LAYOUT
    ======================== */
    .container {
      max-width: 1200px;
      margin: 20px auto;
      padding: 0 16px 32px;
    }

    .screen { display: none; }
    .screen.active { display: block; }

    /* ========================
       CARD
    ======================== */
    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
      margin-bottom: 18px;
    }

    .title    { margin: 0 0 14px 0; color: var(--blue-dark); font-size: 22px; font-weight: bold; }
    .subtitle { margin: 0 0 10px 0; color: var(--blue-dark); font-size: 18px; font-weight: bold; }

    /* ========================
       GRID / STAT
    ======================== */
    .grid   { display: grid; gap: 16px; }
    .grid-2 { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .grid-3 { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .grid-4 { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }

    .stat {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 18px;
      box-shadow: var(--shadow);
    }

    .stat-label { color: var(--muted); font-size: 13px; margin-bottom: 8px; }
    .stat-value { font-size: 26px; font-weight: bold; }

    .status-open   { color: var(--green); }
    .status-closed { color: var(--red); }

    /* Barra de progresso meta/realizada */
    .progress-wrap {
      margin-top: 14px;
      background: #E8EEF4;
      border-radius: 99px;
      height: 7px;
      overflow: hidden;
    }

    .progress-bar {
      height: 100%;
      border-radius: 99px;
      background: var(--blue-mid);
      transition: width 0.4s ease;
    }

    .progress-label {
      font-size: 11px;
      color: var(--muted);
      margin-top: 5px;
      text-align: right;
    }

    /* ========================
       BOTÕES — Hierarquia Corporativa
    ======================== */
    .menu-buttons {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }

    button {
      border: none;
      border-radius: 8px;
      padding: 11px 16px;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.15s ease, box-shadow 0.15s ease;
      font-size: 14px;
      letter-spacing: 0.2px;
    }

    button:hover  { filter: brightness(1.08); box-shadow: 0 2px 8px rgba(0,0,0,0.13); }
    button:active { filter: brightness(0.95); }
    button:disabled { opacity: 0.45; cursor: not-allowed; filter: none; box-shadow: none; }

    /* Ação principal do fluxo operacional */
    .btn-primary   { background: var(--blue-dark); color: #fff; }
    /* Ação de destaque (registrar — mais usada no dia) */
    .btn-secondary { background: var(--blue-mid);  color: #fff; }
    /* Ações neutras / navegação */
    .btn-light     { background: #fff; color: var(--slate); border: 1px solid var(--border); }
    /* Ação de encerramento — tom sóbrio, não alarme */
    .btn-warning   { background: var(--slate); color: #fff; }
    /* Apenas para ações destrutivas irreversíveis */
    .btn-danger    { background: var(--red); color: #fff; }
    /* Sucesso */
    .btn-success   { background: var(--green); color: #fff; }

    /* ========================
       FORMULÁRIOS
    ======================== */
    input, select, textarea {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 10px;
      font-size: 14px;
      background: #fff;
    }

    label {
      display: block;
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 6px;
      font-weight: bold;
    }

    .field         { margin-bottom: 14px; }
    .row           { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 14px; }

    /* ========================
       LOGIN
    ======================== */
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: #fff;
      border-radius: 18px;
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      padding: 28px;
    }

    .login-title {
      margin: 0 0 20px 0;
      text-align: center;
      color: var(--blue-dark);
      font-size: 28px;
      font-weight: bold;
    }

    /* ========================
       MISC
    ======================== */
    .small          { font-size: 12px; color: var(--muted); }
    .hidden         { display: none !important; }
    .toolbar        { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .badge          { display: inline-block; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: bold; background: #eef5fb; color: var(--blue-dark); }
    .footer-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
    .section-divider { height: 1px; background: #eaeaea; margin: 18px 0; }

    .notice         { padding: 12px 14px; border-radius: 12px; font-size: 14px; margin-bottom: 14px; }
    .notice-info    { background: #eef5fb; color: var(--blue-dark); border: 1px solid #d7e7f6; }
    .notice-success { background: #edf7ee; color: var(--green);    border: 1px solid #cfe7d2; }
    .notice-error   { background: #fdeeee; color: var(--red);      border: 1px solid #f4caca; }

    .checkbox-list  { max-height: 220px; overflow: auto; border: 1px solid var(--border); border-radius: 12px; padding: 10px; background: #fff; }
    .checkbox-item  { display: flex; gap: 10px; align-items: flex-start; padding: 8px 4px; border-bottom: 1px solid #f0f0f0; }
    .checkbox-item:last-child { border-bottom: none; }
    .checkbox-item input { width: auto; margin-top: 2px; }

    table           { width: 100%; border-collapse: collapse; margin-top: 10px; background: #fff; border-radius: 12px; overflow: hidden; }
    th, td          { padding: 12px; border-bottom: 1px solid #eee; text-align: left; font-size: 14px; }
    th              { background: #F8FAFC; color: var(--blue-dark); }
  </style>
</head>
<body>

  <div id="app"></div>

  <script>
    /* ================================================
     * ESTADO GLOBAL
     * ================================================ */
    var APP = {
      user: null,
      dashboard: {
        statusDia: 'FECHADO',
        metaDia: 0,
        realizada: 0,
        faltam: 0
      },
      quartos: [],
      camareiras: [],
      camareirasDoDia: [],
      naoConformidades: [],
      currentScreen: 'login',
      pollingInterval: null
    };

    /* ================================================
     * INIT
     * ================================================ */
    document.addEventListener('DOMContentLoaded', initApp);

    function initApp() {
      var savedUser   = localStorage.getItem('gov360_user');
      var savedScreen = localStorage.getItem('gov360_screen') || 'login';

      if (savedUser) {
        APP.user = JSON.parse(savedUser);
        APP.currentScreen = (savedScreen === 'login') ? 'menu' : savedScreen;
        renderApp();
        preloadData(function() {
          refreshDashboard();
          startPolling();
          showScreen(APP.currentScreen);
        });
      } else {
        renderApp();
        showScreen('login');
      }
    }

    function renderApp() {
      var app = document.getElementById('app');
      if (!APP.user) {
        app.innerHTML = renderLogin();
      } else {
        app.innerHTML = renderMainLayout();
      }
    }

    /* ================================================
     * RENDER LOGIN
     * ================================================ */
    function renderLogin() {
      return `
        <div class="login-wrap">
          <div class="login-card">
            <h1 class="login-title">Gov360</h1>
            <div class="field">
              <label>Usuário</label>
              <input type="text" id="loginUsuario" placeholder="Digite o usuário">
            </div>
            <div class="field">
              <label>Senha</label>
              <input type="password" id="loginSenha" placeholder="Digite a senha">
            </div>
            <button id="btnEntrar" class="btn-primary" style="width:100%" onclick="handleLogin()">Entrar</button>
            <div class="small" style="margin-top:14px; text-align:center;">
              Governança 360 • Controle de Auditoria Operacional
            </div>
          </div>
        </div>
      `;
    }

    /* ================================================
     * RENDER MAIN LAYOUT
     * Contém TODAS as telas dentro do #app.
     * ================================================ */
    function renderMainLayout() {
      var nivelUser = APP.user.nivel;

      return `
        <!-- TOPBAR -->
        <div class="topbar">
          <div class="brand">Gov360</div>
          <div class="userbox">
            <div class="userbox-icon">${escapeHtml(APP.user.nome.charAt(0).toUpperCase())}</div>
            <div>
              <div class="userbox-nome">${escapeHtml(APP.user.nome)}</div>
              <div class="userbox-cargo">${escapeHtml(APP.user.cargo || getCargoNome(APP.user.nivel))}</div>
            </div>
          </div>
        </div>

        <div class="container">

          <!-- =================== MENU =================== -->
          <div id="screen-menu" class="screen">
            <div class="card">
              <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:8px; margin-bottom:14px;">
                <h2 class="title" style="margin:0;">Menu Principal</h2>
                <div id="dataDoDia" style="font-size:13px; color:var(--muted); font-weight:600; padding-top:4px;"></div>
              </div>

              <div class="grid grid-4">
                <div class="stat">
                  <div class="stat-label">Status do Dia</div>
                  <div id="statStatus" class="stat-value status-closed">FECHADO</div>
                </div>
                <div class="stat">
                  <div class="stat-label">Meta do Dia</div>
                  <div id="statMeta" class="stat-value">0</div>
                </div>
                <div class="stat">
                  <div class="stat-label">Realizada</div>
                  <div id="statRealizada" class="stat-value">0</div>
                </div>
                <div class="stat">
                  <div class="stat-label">Faltam</div>
                  <div id="statFaltam" class="stat-value">0</div>
                </div>
              </div>

              <!-- Barra de progresso meta x realizada -->
              <div id="progressoWrap" style="margin-top:16px; display:none;">
                <div class="progress-wrap">
                  <div id="progressoBar" class="progress-bar" style="width:0%"></div>
                </div>
                <div id="progressoLabel" class="progress-label">0 de 0 auditorias realizadas</div>
              </div>

              <div class="section-divider"></div>

              <div class="menu-buttons">
                <button class="btn-primary"   onclick="showScreen('iniciarDia')">Iniciar Dia</button>
                <button class="btn-secondary" onclick="openRegistrarAuditoria()">Registrar Auditoria</button>
                <button class="btn-light"     onclick="showScreen('diario')">Diário</button>
                <button class="btn-warning"   onclick="handleEncerrarDia()">Encerrar Dia</button>
                ${[0, 2].includes(nivelUser) ? `<button class="btn-light" onclick="showScreen('dashboard')">Dashboard</button>` : ''}
                ${[0, 2].includes(nivelUser) ? `<button class="btn-light" onclick="showScreen('relatorios')">Relatórios</button>` : ''}
                ${nivelUser === 0            ? `<button class="btn-light" onclick="openConfiguracoes()">Configurações</button>` : ''}
                <button class="btn-danger" onclick="logout()">Sair</button>
              </div>
            </div>
          </div>

          <!-- =================== INICIAR DIA =================== -->
          <div id="screen-iniciarDia" class="screen">
            <div class="card">
              <div class="toolbar">
                <button class="btn-light" onclick="showScreen('menu')">← Voltar ao Menu</button>
              </div>
              <h2 class="title">Iniciar Dia</h2>

              <div class="notice notice-info">
                O sistema calculará automaticamente a meta com base no percentual configurado.
              </div>

              <div class="field">
                <label>Total de UH para vistoriar no dia (base operacional)</label>
                <input type="number" id="inputTotalUH" min="1" placeholder="Ex.: 100">
              </div>

              <div class="field">
                <label>Selecione as camareiras em operação hoje</label>
                <div id="listaCamareirasDia" class="checkbox-list"></div>
              </div>

              <div class="footer-actions">
                <button id="btnIniciarDia" class="btn-primary" onclick="handleIniciarDia()">
                  Iniciar Dia
                </button>
              </div>
            </div>
          </div>

          <!-- =================== REGISTRAR AUDITORIA =================== -->
          <div id="screen-registrarAuditoria" class="screen">
            <div class="card">
              <div class="toolbar">
                <button class="btn-light" onclick="showScreen('menu')">← Voltar ao Menu</button>
              </div>
              <h2 class="title">Registrar Auditoria</h2>

              <div class="row">
                <div class="field" id="quartoFieldWrap">
                  <label>Número do quarto</label>
                  <input list="quartosList" id="auditQuarto" placeholder="Digite ou selecione o quarto">
                  <datalist id="quartosList"></datalist>
                </div>

                <div class="field">
                  <label>Camareira</label>
                  <select id="auditCamareira">
                    <option value="">Selecione</option>
                  </select>
                </div>
              </div>

              <div class="row">
                <div class="field">
                  <label>Tipo de atuação</label>
                  <select id="auditAreaTipo" onchange="onAreaTipoChange()">
