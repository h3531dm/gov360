        box.innerHTML = '<div class="notice notice-info" style="margin-top:16px;">' + escapeHtml(msgVazio) + '</div>';
        return;
      }

      var periodoTxt = '';
      if (dataIni || dataFim) periodoTxt = ' • Período: ' + (dataIni || '?') + ' até ' + (dataFim || '?');
      var pessoaTxt = pessoa ? ' • ' + pessoa : '';

      var html = '';

      // ── 1. FICHA DE DESEMPENHO (sintético) ──────────────────────────────
      if (tipo === 'sintetico') {
        var totalGeral = 0, confGeral = 0, ncGeral = 0;
        data.forEach(function(r) { totalGeral += r.total; confGeral += r.conformes; ncGeral += r.naoConformes; });

        html += '<div class="card" style="margin-top:16px;">';
